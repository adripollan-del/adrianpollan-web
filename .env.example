# ─────────────────────────────────────────────────────────────────
# Variables de entorno requeridas para la web adrianpollan.com
#
# LOCAL:    copia este archivo a .env.local y rellena los valores.
# VERCEL:   añadir en el dashboard del proyecto (Settings → Environment
#           Variables) ANTES del primer deploy. Sin ellas los endpoints
#           correspondientes devolverán 500.
# ─────────────────────────────────────────────────────────────────

# ── Mailchimp ──────────────────────────────────────────────────────
# API key. El sufijo (-us1, -us2, etc.) identifica el datacenter
# y se extrae automáticamente desde el código.
MAILCHIMP_API_KEY=

# ID de la audiencia "Newsletter general" → /api/newsletter
MAILCHIMP_NEWSLETTER_LIST_ID=

# ID de la audiencia "Lista de espera El Método ADRIÁN" → /api/libro
MAILCHIMP_LIBRO_LIST_ID=

# ID de la audiencia "Usuarios Herramientas" → /api/herramientas/email
MAILCHIMP_HERRAMIENTAS_AUDIENCE_ID=

# ID de la audiencia "Clientes Plantillas" → /api/lemon/webhook
MAILCHIMP_PLANTILLAS_AUDIENCE_ID=

# ── Resend ─────────────────────────────────────────────────────────
# Clave de API para envío de emails transaccionales.
# Usada en /api/contact y /api/herramientas/email.
RESEND_API_KEY=

# ── Anthropic ──────────────────────────────────────────────────────
# Clave de API para el chat de Robi (Haiku 4.5).
# Usada en /api/chat.
ANTHROPIC_API_KEY=

# ── Lemon Squeezy ──────────────────────────────────────────────────
# Secreto para verificar la firma HMAC SHA256 del webhook de compras.
# Usada en /api/lemon/webhook.
LEMONSQUEEZY_SIGNING_SECRET=

# ── Upstash Redis ──────────────────────────────────────────────────
# URL y token del cliente REST de Upstash Redis.
# Usados en src/lib/rate-limit.ts (rate limiting de todos los endpoints públicos).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Unsplash ───────────────────────────────────────────────────────
# Access key para descargar imágenes en el script de creación de artículos.
# Usada en create-article.mjs.
UNSPLASH_ACCESS_KEY=
